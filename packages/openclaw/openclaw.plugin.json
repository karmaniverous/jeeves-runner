{
  "id": "jeeves-runner-openclaw",
  "name": "Jeeves Runner",
  "description": "Job execution engine management - status, troubleshooting, and operational tools for jeeves-runner.",
  "version": "0.7.13",
  "skills": [
    "dist/skills/jeeves-runner"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiUrl": {
        "type": "string",
        "description": "jeeves-runner API base URL",
        "default": "http://127.0.0.1:1937"
      },
      "configRoot": {
        "type": "string",
        "description": "Jeeves platform config root directory (e.g., j:/config)"
      }
    }
  },
  "contracts": {
    "tools": [
      "runner_status",
      "runner_config",
      "runner_config_apply",
      "runner_service",
      "runner_list_queues",
      "runner_queue_status",
      "runner_queue_peek",
      "runner_list_namespaces",
      "runner_query_state",
      "runner_query_collection",
      "runner_create_job",
      "runner_update_job",
      "runner_delete_job",
      "runner_update_script",
      "runner_jobs",
      "runner_trigger",
      "runner_runs",
      "runner_job_detail",
      "runner_enable",
      "runner_disable"
    ]
  },
  "uiHints": {
    "apiUrl": {
      "label": "Runner API URL",
      "placeholder": "http://127.0.0.1:1937"
    },
    "configRoot": {
      "label": "Config Root",
      "placeholder": "/path/to/config"
    }
  }
}
